generator client {
  provider = "prisma-client-js"
}

/*datasource db {
  provider = "postgresql"
  url       = env("DIRECT_URL")    // app uses Accelerate
  directUrl = env("DATABASE_URL")  // migrations & Studio use direct
}*/
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  username      String         @unique
  password      String
  bio           String? 
  profilePic    String?
  currency      Int            @default(0)
  isAdmin       Boolean        @default(false)
  isPublic      Boolean        @default(false)
  lastDailyPack DateTime       @default(now())
  createdAt     DateTime       @default(now())
  Inventory     Inventory[]
  tradeList     TradeList[]
  tradeOffer    TradeOffer[]
}

model BannedEmail {
  id    Int     @id @default(autoincrement())
  email String  @unique
  createdAt DateTime @default(now())
}

model Card {
  id          Int    @id @default(autoincrement())
  short_name  String
  long_name   String
  rating      Int
  nationality String
  positions   String

  //Physical Stats
  age       Int
  height_cm Int
  weight_kg Int
  foot      String

  // Game Stats
  pace      Int
  shooting  Int
  passing   Int
  dribbling Int
  defending Int
  physical  Int

  playerImageURL  String
  setCode         String?
  collectorNumber String?
  inventoryItems  Inventory[]
  tradeList       TradeList[]
  tradeOffers     TradeOffer[]
}

model Inventory {
  id       Int  @id @default(autoincrement())
  cardId   Int
  userId   Int
  card     Card @relation(fields: [cardId], references: [id])
  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quantity Int  @default(1)

  @@unique([userId, cardId])
}

model TradeList {
  id        Int           @id @default(autoincrement())
  userId    Int
  user      User          @relation(fields: [userId], references: [id])
  cardId    Int
  card      Card          @relation(fields: [cardId], references: [id])
  status    TradeStatus   @default(AVAILABLE)
  createdAt DateTime      @default(now())
  
  // Relation to incoming offers
  tradeOffers    TradeOffer[]
}

model TradeOffer {
  id             Int         @id @default(autoincrement())
  tradeListId    Int         // The specific listing being bid on
  offeringUserId Int         // Who is making the offer
  offeredCardId  Int         // Which card they are giving up
  status         OfferStatus @default(PENDING)
  createdAt      DateTime    @default(now())

  tradeList    TradeList @relation(fields: [tradeListId], references: [id], onDelete: Cascade)
  offeringUser User      @relation(fields: [offeringUserId], references: [id])
  offeredCard  Card      @relation(fields: [offeredCardId], references: [id])
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TradeStatus {
  AVAILABLE
  PENDING
  TRADED
  HIDDEN
}
