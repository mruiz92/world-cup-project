// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DIRECT_URL") // app uses Accelerate
  directUrl = env("DATABASE_URL") // migrations & Studio use direct
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  email         String    @unique
  password      String
  profilePic    String?
  currency      Int       @default(0)
  lastDailyPack DateTime?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())

  inventory Inventory[]
  tradeList TradeList[]

  // Add these relation fields
  sentTradeRequests     TradeRequest[] @relation("requester")
  receivedTradeRequests TradeRequest[] @relation("receiver")

  @@map("users")
}

model TradeRequest {
  id          Int  @id @default(autoincrement())
  requesterId Int
  requester   User @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiverId  Int
  receiver    User @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  requestedCardId Int
  requestedCard   Card @relation("requestedCard", fields: [requestedCardId], references: [id])

  offeredCardId Int
  offeredCard   Card @relation("offeredCard", fields: [offeredCardId], references: [id])

  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())

  @@unique([requesterId, receiverId, requestedCardId, offeredCardId])
}

model Card {
  id          Int    @id @default(autoincrement())
  short_name  String
  long_name   String
  rating      Int
  nationality String
  positions   String

  //Physical Stats
  age       Int
  height_cm Int
  weight_kg Int
  foot      String

  // Game Stats
  pace      Int
  shooting  Int
  passing   Int
  dribbling Int
  defending Int
  physical  Int

  playerImageURL  String
  setCode         String?
  collectorNumber String?
  inventoryItems  Inventory[]
  tradeList       TradeList[]
  requestedCards  TradeRequest[] @relation("requestedCard")
  offeredCards    TradeRequest[] @relation("offeredCard")

  @@map("cards")
}

model Inventory {
  id       Int  @id @default(autoincrement())
  userId   Int
  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId   Int
  card     Card @relation(fields: [cardId], references: [id])
  quantity Int  @default(1)

  @@unique([userId, cardId])
  @@map("inventory")
}

model TradeList {
  id     Int    @id @default(autoincrement())
  userId Int
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId Int
  card   Card   @relation(fields: [cardId], references: [id])
  status String @default("AVAILABLE")

  @@unique([userId, cardId])
  @@map("trade_list")
}

model BannedEmail {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("banned_emails")
}

enum TradeStatus {
  AVAILABLE
  PENDING
  TRADED
  HIDDEN
}
